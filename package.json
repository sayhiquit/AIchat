{
  "name": "ai-relationship-butler",
  "version": "0.1.6",
  "description": "AI 人际管家桌面版",
  "main": "electron/main.js",
  "private": true,
  "scripts": {
    "validate": "node scripts/validate.js",
    "desktop": "electron .",
    "pack:win": "electron-builder --win --x64",
    "dist:win": "electron-builder --win --x64 --publish never"
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.ai.relationship.butler",
    "productName": "AI人际管家",
    "asar": true,
    "files": [
      "index.html",
      "styles.css",
      "app.js",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "AI人际管家-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false
    }
  }
}
